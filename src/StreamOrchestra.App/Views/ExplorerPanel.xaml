<UserControl x:Class="StreamOrchestra.App.Views.ExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="360">
    <UserControl.Resources>
        <!-- 주소창 옆 탐색 아이콘 버튼: 어두운 패널 톤에 맞춘 사각 아이콘 버튼 -->
        <Style x:Key="NavIconButton" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#1B2531" />
            <Setter Property="BorderBrush" Value="#2D3642" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#243140" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A4757" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D3C4D" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A5A6E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="#0F141B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="ExplorerDragSource"
                Grid.Row="0"
                Background="#17202A"
                BorderBrush="#2D3642"
                BorderThickness="0,0,0,1"
                Padding="8"
                Cursor="Hand"
                ToolTip="현재 탐색 URL을 슬롯으로 드래그"
                PreviewMouseLeftButtonDown="ExplorerDragSource_PreviewMouseLeftButtonDown"
                MouseMove="ExplorerDragSource_MouseMove">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="SOOP 탐색"
                           Foreground="#F3F6FA"
                           FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#101820"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource NavIconButton}"
                            ToolTip="뒤로"
                            Click="BackButton_Click">
                        <Image Source="/Assets/arrow-back.png"
                               Width="18"
                               Height="18"
                               Stretch="Uniform" />
                    </Button>
                    <Button Style="{StaticResource NavIconButton}"
                            ToolTip="이동"
                            Click="GoButton_Click">
                        <Image Source="/Assets/arrow-forward.png"
                               Width="18"
                               Height="18"
                               Stretch="Uniform" />
                    </Button>
                    <Button Style="{StaticResource NavIconButton}"
                            ToolTip="새로고침"
                            Click="RefreshButton_Click">
                        <Image Source="/Assets/refresh.png"
                               Width="18"
                               Height="18"
                               Stretch="Uniform" />
                    </Button>
                </StackPanel>
                <TextBox x:Name="ExplorerUrlTextBox"
                         Grid.Column="1"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Text="https://www.sooplive.co.kr"
                         KeyDown="ExplorerUrlTextBox_KeyDown" />
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Background="#05070A">
            <wv2:WebView2 x:Name="Browser" />
            <Border x:Name="InitializationOverlay"
                    Background="#05070A">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="12">
                    <TextBlock x:Name="InitializationTextBlock"
                               Text="Initializing explorer..."
                               Foreground="#B9C2CC"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock x:Name="ProfilePathTextBlock"
                               Foreground="#788492"
                               FontSize="11"
                               TextAlignment="Center"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
