<UserControl x:Class="StreamOrchestra.App.Views.ExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="360">
    <Grid Background="#0F141B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="ExplorerDragSource"
                Grid.Row="0"
                Background="#17202A"
                BorderBrush="#2D3642"
                BorderThickness="0,0,0,1"
                Padding="8"
                Cursor="Hand"
                ToolTip="현재 탐색 URL을 슬롯으로 드래그"
                PreviewMouseLeftButtonDown="ExplorerDragSource_PreviewMouseLeftButtonDown"
                MouseMove="ExplorerDragSource_MouseMove">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="SOOP 탐색"
                           Foreground="#F3F6FA"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="↗"
                           Foreground="#B9C2CC"
                           FontWeight="SemiBold"
                           ToolTip="현재 탐색 URL을 슬롯으로 드래그" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#101820"
                Padding="8">
        <StackPanel>
            <TextBox x:Name="ExplorerUrlTextBox"
                     Height="28"
                         Text="https://www.sooplive.co.kr"
                         VerticalContentAlignment="Center"
                         KeyDown="ExplorerUrlTextBox_KeyDown" />
                <WrapPanel Margin="0,6,0,0">
                    <Button Content="Go"
                            MinWidth="44"
                            Height="28"
                            Margin="0,0,6,0"
                            Click="GoButton_Click" />
                    <Button Content="Back"
                            MinWidth="52"
                            Height="28"
                            Margin="0,0,6,0"
                            Click="BackButton_Click" />
                    <Button Content="Refresh"
                            MinWidth="68"
                            Height="28"
                            Margin="0,0,6,0"
                            Click="RefreshButton_Click" />
                    <Button Content="선택 슬롯에 넣기"
                            MinWidth="112"
                            Height="28"
                            Click="UseCurrentUrlButton_Click" />
                </WrapPanel>
                <TextBlock Text="앱 즐겨찾기"
                           Foreground="#F3F6FA"
                           FontWeight="SemiBold"
                           Margin="0,10,0,4" />
                <TextBox x:Name="FavoriteNameTextBox"
                         Height="28"
                         VerticalContentAlignment="Center"
                         ToolTip="Favorite name" />
                <WrapPanel Margin="0,6,0,0">
                    <Button Content="현재 URL 추가"
                            MinWidth="100"
                            Height="28"
                            Margin="0,0,6,0"
                            Click="AddFavoriteButton_Click" />
                    <ComboBox x:Name="FavoriteComboBox"
                              Width="154"
                              Height="28"
                              DisplayMemberPath="Name"
                              Margin="0,0,6,0" />
                    <Button Content="선택 슬롯에 넣기"
                            MinWidth="112"
                            Height="28"
                            Click="UseFavoriteButton_Click" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2"
              Background="#05070A">
            <wv2:WebView2 x:Name="Browser" />
            <Border x:Name="InitializationOverlay"
                    Background="#05070A">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="12">
                    <TextBlock x:Name="InitializationTextBlock"
                               Text="Initializing explorer..."
                               Foreground="#B9C2CC"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock x:Name="ProfilePathTextBlock"
                               Foreground="#788492"
                               FontSize="11"
                               TextAlignment="Center"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
