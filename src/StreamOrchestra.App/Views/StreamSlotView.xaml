<UserControl x:Class="StreamOrchestra.App.Views.StreamSlotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="240"
             d:DesignWidth="360">
    <Border x:Name="SlotBorder"
            Margin="4"
            BorderBrush="#2D3642"
            BorderThickness="1"
            Background="#0F141B"
            AllowDrop="True"
            DragOver="SlotBorder_DragOver"
            Drop="SlotBorder_Drop"
            PreviewMouseLeftButtonDown="SlotBorder_PreviewMouseLeftButtonDown"
            MouseMove="SlotBorder_MouseMove"
            PreviewMouseWheel="SlotBorder_PreviewMouseWheel">
        <Grid>
            <Grid Background="#05070A">
                <wv2:WebView2 x:Name="Browser"
                              AllowExternalDrop="True"
                              PreviewMouseLeftButtonDown="SlotBorder_PreviewMouseLeftButtonDown"
                              MouseMove="SlotBorder_MouseMove"
                              PreviewMouseWheel="SlotBorder_PreviewMouseWheel" />
                <Border x:Name="InitializationOverlay"
                        Background="#05070A">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="InitializationTextBlock"
                                   Text="Initializing WebView2..."
                                   Foreground="#B9C2CC"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="ProfilePathTextBlock"
                                   Foreground="#788492"
                                   FontSize="11"
                                   TextAlignment="Center"
                                   Margin="10,6,10,0" />
                    </StackPanel>
                </Border>
            </Grid>
            <primitives:Popup x:Name="VolumeIndicatorPopup"
                              PlacementTarget="{Binding ElementName=SlotBorder}"
                              Placement="Center"
                              IsOpen="False"
                              AllowsTransparency="True"
                              IsHitTestVisible="False"
                              Focusable="False">
                <Border x:Name="VolumeIndicatorOverlay"
                        Background="#B3000000"
                        Padding="12,6"
                        CornerRadius="8">
                    <TextBlock x:Name="VolumeIndicatorTextBlock"
                               Text="100%"
                               Foreground="#FAFAFA"
                               FontSize="24"
                               FontWeight="Bold"/>
                </Border>
            </primitives:Popup>
            <primitives:Popup x:Name="RemoveSlotPopup"
                              PlacementTarget="{Binding ElementName=SlotBorder}"
                              Placement="Relative"
                              IsOpen="False"
                              AllowsTransparency="True"
                              Focusable="False"
                              StaysOpen="True">
                <Button x:Name="RemoveSlotButton"
                        Width="64"
                        Height="64"
                        Padding="0"
                        Background="#E01F2937"
                        BorderBrush="#F3F6FA"
                        BorderThickness="2"
                        Foreground="#F3F6FA"
                        ToolTip="이 화면 제거 (Ctrl)"
                        Click="RemoveSlotButton_Click">
                    <Image Source="/Assets/delete-icon.png"
                           Width="32"
                           Height="32"
                           Stretch="Uniform" />
                </Button>
            </primitives:Popup>
            <primitives:Popup x:Name="SwapModePopup"
                              PlacementTarget="{Binding ElementName=SlotBorder}"
                              Placement="Center"
                              IsOpen="False"
                              AllowsTransparency="True"
                              Focusable="False"
                              StaysOpen="True">
                <Border x:Name="SwapOverlayBorder"
                        Width="{Binding ActualWidth, ElementName=SlotBorder}"
                        Height="{Binding ActualHeight, ElementName=SlotBorder}"
                        Background="#3315A3FF"
                        BorderBrush="#8015A3FF"
                        BorderThickness="2"
                        Cursor="SizeAll"
                        AllowDrop="True"
                        PreviewMouseLeftButtonDown="SwapOverlay_PreviewMouseLeftButtonDown"
                        MouseMove="SwapOverlay_MouseMove"
                        DragOver="SwapOverlay_DragOver"
                        DragLeave="SwapOverlay_DragLeave"
                        Drop="SwapOverlay_Drop">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#B3000000"
                            CornerRadius="6"
                            Padding="14,10"
                            IsHitTestVisible="False">
                        <StackPanel>
                            <TextBlock Text="⇄"
                                       Foreground="#F3F6FA"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="드래그하여 위치 교체 (Shift)"
                                       Foreground="#F3F6FA"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Border>
            </primitives:Popup>
        </Grid>
    </Border>
</UserControl>
