<Window x:Class="StreamOrchestra.App.Views.LayoutEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="레이아웃 편집"
        Height="760"
        Width="1120"
        MinHeight="640"
        MinWidth="940"
        WindowStartupLocation="CenterOwner"
        Background="#0B0F14">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 왼쪽: 레이아웃 목록(세로 스크롤) + 새 레이아웃/삭제 -->
        <Border Grid.Column="0"
                Background="#0F141B"
                BorderBrush="#2D3642"
                BorderThickness="1"
                Padding="10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Vertical"
                            HorizontalAlignment="Stretch"
                            Margin="0,10,0,0">
                    <Button Content="새 레이아웃"
                            Height="30"
                            Margin="0,0,0,8"
                            Click="NewCustomLayoutButton_Click" />
                    <Button Content="삭제"
                            Height="30"
                            Click="DeleteCustomLayoutButton_Click" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="CustomLayoutListPanel" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Background="#0F141B"
                BorderBrush="#2D3642"
                BorderThickness="1"
                Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 헤더: 이름 + 요약 + 미저장 표시 -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="이름"
                                           Foreground="#F3F6FA"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBox x:Name="LayoutNameTextBox"
                                         Grid.Column="1"
                                         Height="28"
                                         MaxWidth="320"
                                         HorizontalAlignment="Left"
                                         MinWidth="200"
                                         Foreground="#111827"
                                         VerticalContentAlignment="Center"
                                         TextChanged="LayoutNameTextBox_TextChanged" />
                                <TextBlock x:Name="LayoutSummaryTextBlock"
                                           Grid.Column="2"
                                           Text=""
                                           Foreground="#B9C2CC"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="12,0,12,0" />
                                <TextBlock x:Name="UnsavedIndicator"
                                           Grid.Column="3"
                                           Text="● 미저장"
                                           Foreground="#F2B84B"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                            </Grid>

                            <Border Grid.Row="1"
                                    Background="#05070A"
                                    BorderBrush="#2D3642"
                                    BorderThickness="1"
                                    Padding="8">
                                <ContentControl x:Name="SplitEditorHost"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch" />
                            </Border>

                            <!-- 선택 컨텍스트 바: 선택 상태에 따라 활성/비활성 -->
                            <Border Grid.Row="2"
                                    Background="#121820"
                                    BorderBrush="#2D3642"
                                    BorderThickness="1"
                                    Padding="8,6"
                                    Margin="0,10,0,0">
                                <DockPanel LastChildFill="True">
                                    <TextBlock x:Name="SelectionInfoTextBlock"
                                               DockPanel.Dock="Left"
                                               Text="선택 없음"
                                               Foreground="#B9C2CC"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0" />
                                    <WrapPanel>
                                        <Button x:Name="HorizontalAlignButton"
                                                Content="↔ 가로 정렬"
                                                Height="28"
                                                MinWidth="92"
                                                Margin="0,0,8,0"
                                                ToolTipService.ShowOnDisabled="True"
                                                Click="HorizontalAlignButton_Click" />
                                        <Button x:Name="VerticalAlignButton"
                                                Content="↕ 세로 정렬"
                                                Height="28"
                                                MinWidth="92"
                                                Margin="0,0,8,0"
                                                ToolTipService.ShowOnDisabled="True"
                                                Click="VerticalAlignButton_Click" />
                                        <Button x:Name="MergeSelectedZonesButton"
                                                Content="⛶ 선택 병합"
                                                Height="28"
                                                MinWidth="92"
                                                Margin="0,0,8,0"
                                                ToolTipService.ShowOnDisabled="True"
                                                Click="MergeSelectedZonesButton_Click" />
                                        <Button x:Name="ResetZoneSizeButton"
                                                Content="⊟ 비율 초기화"
                                                Height="28"
                                                MinWidth="100"
                                                ToolTip="열/행 비율을 균등하게 초기화"
                                                Click="ResetZoneSizeButton_Click" />
                                    </WrapPanel>
                                </DockPanel>
                            </Border>

                            <!-- 푸터: 상태 메시지(좌) + 저장 / 저장 후 적용 / 닫기(우) -->
                            <DockPanel Grid.Row="3"
                                       Margin="0,10,0,0"
                                       LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal">
                                    <Button Content="저장"
                                            Height="32"
                                            MinWidth="80"
                                            Margin="0,0,8,0"
                                            Click="SaveCustomLayoutButton_Click" />
                                    <Button Content="저장 후 적용"
                                            Height="32"
                                            MinWidth="110"
                                            Margin="0,0,8,0"
                                            Background="#1F6FEB"
                                            Foreground="#F3F6FA"
                                            ToolTip="저장하고 이 레이아웃을 화면에 바로 적용"
                                            Click="SaveAndApplyButton_Click" />
                                    <Button Content="닫기"
                                            Height="32"
                                            MinWidth="80"
                                            Click="CloseButton_Click" />
                                </StackPanel>
                                <TextBlock x:Name="DialogStatusTextBlock"
                                           Foreground="#B9C2CC"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,12,0" />
                            </DockPanel>
                        </Grid>
        </Border>
    </Grid>
</Window>
