<Window x:Class="StreamOrchestra.App.Views.LayoutEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="레이아웃 편집"
        Height="760"
        Width="1120"
        MinHeight="640"
        MinWidth="940"
        WindowStartupLocation="CenterOwner"
        Background="#0B0F14">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,12"
                   LastChildFill="True">
            <TextBlock DockPanel.Dock="Left"
                       Text="레이아웃 편집"
                       Foreground="#F3F6FA"
                       FontSize="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="DialogStatusTextBlock"
                       DockPanel.Dock="Right"
                       Foreground="#B9C2CC"
                       TextAlignment="Right"
                       VerticalAlignment="Center" />
        </DockPanel>

        <TabControl x:Name="EditorTabControl"
                    Grid.Row="1"
                    Background="#121820"
                    BorderBrush="#2D3642"
                    Foreground="#F3F6FA">
            <TabItem Header="템플릿">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="#0F141B"
                            BorderBrush="#2D3642"
                            BorderThickness="1"
                            Padding="10">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Bottom"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                <Button Content="사용자 지정으로 복사"
                                        MinWidth="128"
                                        Height="30"
                                        Margin="0,0,8,0"
                                        Click="CopyTemplateToCustomButton_Click" />
                                <Button Content="적용"
                                        MinWidth="72"
                                        Height="30"
                                        Click="ApplySelectedLayoutButton_Click" />
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TemplateListPanel" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#05070A"
                            BorderBrush="#2D3642"
                            BorderThickness="1"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TemplatePreviewTitleTextBlock"
                                       Grid.Row="0"
                                       Foreground="#F3F6FA"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10" />
                            <ContentControl x:Name="TemplatePreviewHost"
                                            Grid.Row="1" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="사용자 지정">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#0F141B"
                            BorderBrush="#2D3642"
                            BorderThickness="1"
                            Padding="10">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Bottom"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,10,0,0">
                                <Button Content="새 레이아웃"
                                        Height="30"
                                        Margin="0,0,0,8"
                                        Click="NewCustomLayoutButton_Click" />
                                <DockPanel LastChildFill="False">
                                    <Button Content="삭제"
                                            MinWidth="64"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Click="DeleteCustomLayoutButton_Click" />
                                    <Button Content="적용"
                                            MinWidth="64"
                                            Height="30"
                                            Click="ApplySelectedLayoutButton_Click" />
                                </DockPanel>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="CustomLayoutListPanel" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#0F141B"
                            BorderBrush="#2D3642"
                            BorderThickness="1"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0"
                                       Margin="0,0,0,10">
                                <Button x:Name="VerticalSplitButton"
                                        Content="세로분할"
                                        Height="28"
                                        MinWidth="82"
                                        Margin="0,0,8,0"
                                        ToolTip="세로 선을 기준으로 좌/우 분할"
                                        Click="VerticalSplitButton_Click" />
                                <Button x:Name="HorizontalSplitButton"
                                        Content="가로분할"
                                        Height="28"
                                        MinWidth="82"
                                        Margin="0,0,8,0"
                                        ToolTip="가로 선을 기준으로 상/하 분할"
                                        Click="HorizontalSplitButton_Click" />
                                <Button x:Name="RemoveSelectedSlotButton"
                                        Content="슬롯 제거"
                                        Height="28"
                                        MinWidth="82"
                                        Margin="0,0,8,0"
                                        ToolTip="선택 슬롯을 제거하고 형제 영역을 확장"
                                        Click="RemoveSelectedSlotButton_Click" />
                                <Button x:Name="MergeSelectedZonesButton"
                                        Content="선택 병합"
                                        Height="28"
                                        MinWidth="82"
                                        Margin="0,0,8,0"
                                        ToolTip="Ctrl+클릭으로 선택한 인접 zone을 하나로 병합"
                                        Click="MergeSelectedZonesButton_Click" />
                                <Button x:Name="ResetZoneSizeButton"
                                        Content="비율 초기화"
                                        Height="28"
                                        MinWidth="92"
                                        Margin="0,0,8,0"
                                        Click="ResetZoneSizeButton_Click" />
                                <Button Content="저장"
                                        Height="28"
                                        MinWidth="64"
                                        Click="SaveCustomLayoutButton_Click" />
                            </WrapPanel>

                            <Border Grid.Row="1"
                                    Background="#05070A"
                                    BorderBrush="#2D3642"
                                    BorderThickness="1"
                                    Padding="8">
                                <ContentControl x:Name="SplitEditorHost"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch" />
                            </Border>

                            <TextBlock x:Name="SplitEditorHintTextBlock"
                                       Grid.Row="2"
                                       Text="슬롯 내부 클릭은 선택(Ctrl+클릭 다중 선택)입니다. 슬롯 분할은 분할 버튼으로 수행하고, 경계선을 드래그하면 비율이 실시간 조절됩니다."
                                       Foreground="#788492"
                                       Margin="0,8,0,0" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="4"
                            Background="#05070A"
                            BorderBrush="#2D3642"
                            BorderThickness="1"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="저장 결과"
                                       Grid.Row="0"
                                       Foreground="#F3F6FA"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10" />
                            <ContentControl x:Name="EditorPreviewHost"
                                            Grid.Row="1" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="닫기"
                    MinWidth="76"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="CloseButton_Click" />
            <Button Content="적용하고 닫기"
                    MinWidth="112"
                    Height="32"
                    IsDefault="True"
                    Click="ApplySelectedLayoutButton_Click" />
        </StackPanel>
    </Grid>
</Window>
