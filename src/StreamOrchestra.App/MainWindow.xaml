<Window x:Class="StreamOrchestra.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Stream Orchestra Spike"
        Icon="Assets/app-icon.ico"
        Height="1000"
        Width="1600"
        MinHeight="720"
        MinWidth="1100"
        Background="#0B0F14">
    <Window.Resources>
        <!-- 최상단 사이드탭 토글: 어두운 툴바 톤에 맞춘 사각 아이콘 버튼 -->
        <Style x:Key="SidebarToggleButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#243140" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A4757" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D3C4D" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A5A6E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#121820"
                BorderBrush="#2D3642"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <DockPanel LastChildFill="True">
                <Button x:Name="ToggleExplorerButton"
                        DockPanel.Dock="Left"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource SidebarToggleButton}"
                        ToolTip="탐색 숨김"
                        Click="ToggleExplorerButton_Click">
                    <Image x:Name="ToggleExplorerIcon"
                           Source="/Assets/sidebar-close.png"
                           Width="18"
                           Height="18"
                           Stretch="Uniform" />
                </Button>

                <TextBlock x:Name="DiagnosticsTextBlock"
                           DockPanel.Dock="Right"
                           Foreground="#B9C2CC"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />

                <Menu Background="Transparent"
                      Foreground="#F3F6FA"
                      VerticalAlignment="Center">
                    <MenuItem Header="설정">
                        <MenuItem x:Name="LayoutMenuItem"
                                  Header="레이아웃"
                                  Foreground="#111827"
                                  Click="EditLayoutsButton_Click" />
                        <MenuItem Header="업데이트 확인"
                                  Foreground="#111827"
                                  Click="CheckForUpdatesButton_Click" />
                        <MenuItem Header="단축키"
                                  Foreground="#111827"
                                  Click="ShortcutSettingsButton_Click" />
                        <MenuItem Header="프리셋"
                                  Foreground="#111827">
                            <ComboBox x:Name="WorkspaceComboBox"
                                      Width="180"
                                      Height="28"
                                      DisplayMemberPath="Name"
                                      Margin="8,4" />
                            <Separator />
                            <MenuItem Header="불러오기"
                                      Foreground="#111827"
                                      Click="LoadWorkspaceButton_Click" />
                            <MenuItem Header="현재 상태 저장"
                                      Foreground="#111827"
                                      Click="SaveCurrentWorkspaceButton_Click" />
                            <MenuItem Header="다른 이름으로 저장"
                                      Foreground="#111827"
                                      Click="SaveWorkspaceAsButton_Click" />
                        </MenuItem>
                        <MenuItem x:Name="QualityMenuItem"
                                  Header="화질"
                                  Foreground="#111827">
                            <MenuItem Header="1440p"
                                      Tag="q1440"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                            <MenuItem Header="1080p"
                                      Tag="original"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                            <MenuItem Header="720p"
                                      Tag="hd4k"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                            <MenuItem Header="540p"
                                      Tag="hd"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                            <MenuItem Header="360p"
                                      Tag="sd"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <ComboBox x:Name="AudibleQualityComboBox"
                          Width="92"
                          Height="28"
                          SelectedIndex="0"
                          Visibility="Collapsed"
                          SelectionChanged="AudibleQualityComboBox_SelectionChanged">
                    <ComboBoxItem Content="1440p"
                                  Tag="q1440" />
                    <ComboBoxItem Content="1080p"
                                  Tag="original" />
                    <ComboBoxItem Content="720p"
                                  Tag="hd4k" />
                    <ComboBoxItem Content="540p"
                                  Tag="hd" />
                    <ComboBoxItem Content="360p"
                                  Tag="sd" />
                </ComboBox>
            </DockPanel>
        </Border>

        <Grid x:Name="MainContentGrid"
              Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ExplorerColumn"
                                  Width="360" />
                <ColumnDefinition x:Name="ExplorerSplitterColumn"
                                  Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ExplorerBorder"
                    Grid.Column="0"
                    Background="#0F141B"
                    BorderBrush="#2D3642"
                    BorderThickness="0,0,1,0">
                <ContentControl x:Name="ExplorerHost" />
            </Border>

            <GridSplitter x:Name="ExplorerGridSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          Background="#1D2733" />

            <Grid x:Name="SlotsGrid"
                  Grid.Column="2"
                  Margin="6"
                  Background="#05070A"
                  AllowDrop="True"
                  DragOver="SlotsGrid_DragOver"
                  Drop="SlotsGrid_Drop" />
        </Grid>

        <Border Grid.Row="2"
                Background="#121820"
                BorderBrush="#2D3642"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <DockPanel LastChildFill="True">
                <Button x:Name="MuteAllButton"
                        DockPanel.Dock="Right"
                        Margin="10,0,0,0"
                        Padding="10,3"
                        VerticalAlignment="Center"
                        Background="#223044"
                        BorderBrush="#2D3642"
                        BorderThickness="1"
                        Foreground="#F3F6FA"
                        Content="전체 볼륨 0%"
                        ToolTip="모든 화면의 볼륨을 0%로 변경"
                        Click="MuteAllButton_Click" />

                <TextBlock x:Name="StatusTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#B9C2CC"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
