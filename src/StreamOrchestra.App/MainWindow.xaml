<Window x:Class="StreamOrchestra.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Stream Orchestra Spike"
        Height="1000"
        Width="1600"
        MinHeight="720"
        MinWidth="1100"
        Background="#0B0F14">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#121820"
                BorderBrush="#2D3642"
                BorderThickness="0,0,0,1"
                Padding="10">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Margin="10,0,0,0">
                        <ScrollViewer Width="520"
                                      Height="86"
                                      Margin="8,0,0,0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="LayoutSelectorPanel"
                                        Orientation="Horizontal" />
                        </ScrollViewer>
                        <Button Content="레이아웃 편집"
                                Height="30"
                                MinWidth="96"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="EditLayoutsButton_Click" />
                    </StackPanel>
                </DockPanel>

                <DockPanel Margin="0,8,0,0"
                           LastChildFill="False">
                    <TextBlock x:Name="DiagnosticsTextBlock"
                               DockPanel.Dock="Right"
                               Foreground="#B9C2CC"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />
                    <WrapPanel>
                        <TextBlock Text="화질"
                                   Foreground="#F3F6FA"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Margin="0,0,8,0" />
                        <ComboBox x:Name="AudibleQualityComboBox"
                                  Width="92"
                                  Height="28"
                                  SelectedIndex="0"
                                  Margin="0,0,8,0"
                                  SelectionChanged="AudibleQualityComboBox_SelectionChanged">
                            <ComboBoxItem Content="최대화질"
                                          Tag="original" />
                            <ComboBoxItem Content="1080p"
                                          Tag="original" />
                            <ComboBoxItem Content="자동"
                                          Tag="master" />
                            <ComboBoxItem Content="720p"
                                          Tag="hd4k" />
                            <ComboBoxItem Content="540p"
                                          Tag="hd" />
                            <ComboBoxItem Content="360p"
                                          Tag="sd" />
                        </ComboBox>
                        <Button Content="화질 적용"
                                Height="28"
                                MinWidth="82"
                                Margin="0,0,12,0"
                                Click="ApplyQualityPolicyButton_Click" />
                    </WrapPanel>
                </DockPanel>

                <DockPanel Margin="0,8,0,0"
                           LastChildFill="False">
                    <WrapPanel>
                        <TextBlock Text="프리셋"
                                   Foreground="#F3F6FA"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Margin="0,0,8,0" />
                        <ComboBox x:Name="WorkspaceComboBox"
                                  Width="180"
                                  Height="28"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,6,0" />
                        <Button Content="불러오기"
                                Height="28"
                                MinWidth="74"
                                Margin="0,0,6,0"
                                Click="LoadWorkspaceButton_Click" />
                        <Button Content="현재 상태 저장"
                                Height="28"
                                MinWidth="106"
                                Margin="0,0,6,0"
                                Click="SaveCurrentWorkspaceButton_Click" />
                        <Button Content="다른 이름으로 저장"
                                Height="28"
                                MinWidth="124"
                                Margin="0,0,6,0"
                                Click="SaveWorkspaceAsButton_Click" />
                    </WrapPanel>
                </DockPanel>

            </StackPanel>
        </Border>

        <Grid x:Name="MainContentGrid"
              Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ExplorerColumn"
                                  Width="360" />
                <ColumnDefinition x:Name="ExplorerSplitterColumn"
                                  Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ExplorerBorder"
                    Grid.Column="0"
                    Background="#0F141B"
                    BorderBrush="#2D3642"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <ContentControl x:Name="ExplorerHost" />
                    <Button x:Name="ToggleExplorerButton"
                            Height="26"
                            MinWidth="78"
                            Margin="0,6,6,0"
                            Padding="10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Panel.ZIndex="1"
                            Click="ToggleExplorerButton_Click" />
                </Grid>
            </Border>

            <GridSplitter x:Name="ExplorerGridSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          Background="#1D2733" />

            <Grid x:Name="SlotsGrid"
                  Grid.Column="2"
                  Margin="6"
                  Background="#05070A"
                  AllowDrop="True"
                  DragOver="SlotsGrid_DragOver"
                  Drop="SlotsGrid_Drop" />
        </Grid>

        <Border Grid.Row="2"
                Background="#121820"
                BorderBrush="#2D3642"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#B9C2CC"
                       TextWrapping="Wrap" />
        </Border>

        <Popup x:Name="AutoShowExplorerPopup"
               AllowsTransparency="True"
               Focusable="False"
               Placement="AbsolutePoint"
               PopupAnimation="None"
               StaysOpen="True">
            <Button x:Name="AutoShowExplorerButton"
                    Width="24"
                    MinHeight="1"
                    Padding="0"
                    Background="#223044"
                    BorderBrush="#7FA9D8"
                    BorderThickness="0,0,1,0"
                    Click="AutoShowExplorerButton_Click"
                    Focusable="False"
                    Foreground="#F3F6FA"
                    MouseEnter="AutoShowExplorerButton_MouseEnter"
                    MouseLeave="AutoShowExplorerButton_MouseLeave"
                    ToolTip="탐색 표시">
                <TextBlock Text="탐색 표시"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextAlignment="Center">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="-90" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Button>
        </Popup>
    </Grid>
</Window>
