<Window x:Class="StreamOrchestra.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Stream Orchestra Spike"
        Height="1000"
        Width="1600"
        MinHeight="720"
        MinWidth="1100"
        Background="#0B0F14">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#121820"
                BorderBrush="#2D3642"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="DiagnosticsTextBlock"
                           DockPanel.Dock="Right"
                           Foreground="#B9C2CC"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />

                <Menu Background="Transparent"
                      Foreground="#F3F6FA"
                      VerticalAlignment="Center">
                    <MenuItem Header="설정">
                        <MenuItem x:Name="LayoutMenuItem"
                                  Header="레이아웃"
                                  Foreground="#111827"
                                  Click="EditLayoutsButton_Click" />
                        <MenuItem Header="업데이트 확인"
                                  Foreground="#111827"
                                  Click="CheckForUpdatesButton_Click" />
                        <MenuItem Header="프리셋"
                                  Foreground="#111827">
                            <ComboBox x:Name="WorkspaceComboBox"
                                      Width="180"
                                      Height="28"
                                      DisplayMemberPath="Name"
                                      Margin="8,4" />
                            <Separator />
                            <MenuItem Header="불러오기"
                                      Foreground="#111827"
                                      Click="LoadWorkspaceButton_Click" />
                            <MenuItem Header="현재 상태 저장"
                                      Foreground="#111827"
                                      Click="SaveCurrentWorkspaceButton_Click" />
                            <MenuItem Header="다른 이름으로 저장"
                                      Foreground="#111827"
                                      Click="SaveWorkspaceAsButton_Click" />
                        </MenuItem>
                        <MenuItem x:Name="QualityMenuItem"
                                  Header="화질"
                                  Foreground="#111827">
                            <MenuItem Header="1440p"
                                      Tag="q1440"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                            <MenuItem Header="1080p"
                                      Tag="original"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                            <MenuItem Header="720p"
                                      Tag="hd4k"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                            <MenuItem Header="540p"
                                      Tag="hd"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                            <MenuItem Header="360p"
                                      Tag="sd"
                                      Foreground="#111827"
                                      IsCheckable="True"
                                      Click="QualityMenuItem_Click" />
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <ComboBox x:Name="AudibleQualityComboBox"
                          Width="92"
                          Height="28"
                          SelectedIndex="0"
                          Visibility="Collapsed"
                          SelectionChanged="AudibleQualityComboBox_SelectionChanged">
                    <ComboBoxItem Content="1440p"
                                  Tag="q1440" />
                    <ComboBoxItem Content="1080p"
                                  Tag="original" />
                    <ComboBoxItem Content="720p"
                                  Tag="hd4k" />
                    <ComboBoxItem Content="540p"
                                  Tag="hd" />
                    <ComboBoxItem Content="360p"
                                  Tag="sd" />
                </ComboBox>
            </DockPanel>
        </Border>

        <Grid x:Name="MainContentGrid"
              Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ExplorerColumn"
                                  Width="360" />
                <ColumnDefinition x:Name="ExplorerSplitterColumn"
                                  Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ExplorerBorder"
                    Grid.Column="0"
                    Background="#0F141B"
                    BorderBrush="#2D3642"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <ContentControl x:Name="ExplorerHost" />
                    <Button x:Name="ToggleExplorerButton"
                            Height="26"
                            Width="34"
                            MinWidth="26"
                            Margin="0,6,6,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Panel.ZIndex="1"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ToolTip="탐색 숨김"
                            Click="ToggleExplorerButton_Click">
                        <Image Source="Assets/explorer-toggle.png"
                               Width="14"
                               Height="14"
                               Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <GridSplitter x:Name="ExplorerGridSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          Background="#1D2733" />

            <Grid x:Name="SlotsGrid"
                  Grid.Column="2"
                  Margin="6"
                  Background="#05070A"
                  AllowDrop="True"
                  DragOver="SlotsGrid_DragOver"
                  Drop="SlotsGrid_Drop" />
        </Grid>

        <Border Grid.Row="2"
                Background="#121820"
                BorderBrush="#2D3642"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#B9C2CC"
                       TextWrapping="Wrap" />
        </Border>

        <Border x:Name="AutoShowExplorerHitTarget"
                Grid.Row="1"
                Width="28"
                HorizontalAlignment="Left"
                Background="Transparent"
                Panel.ZIndex="10"
                Visibility="Collapsed"
                MouseEnter="AutoShowExplorerHitTarget_MouseEnter"
                MouseLeave="AutoShowExplorerHitTarget_MouseLeave" />

        <Popup x:Name="AutoShowExplorerPopup"
               AllowsTransparency="True"
               Focusable="False"
               IsOpen="False"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=AutoShowExplorerHitTarget}"
               PopupAnimation="None"
               StaysOpen="True">
            <Button x:Name="AutoShowExplorerButton"
                    Width="24"
                    Height="{Binding ActualHeight, ElementName=MainContentGrid}"
                    MinHeight="1"
                    Padding="0"
                    Background="#223044"
                    BorderBrush="#7FA9D8"
                    BorderThickness="0,0,1,0"
                    Click="AutoShowExplorerButton_Click"
                    Focusable="False"
                    Foreground="#F3F6FA"
                    MouseEnter="AutoShowExplorerButton_MouseEnter"
                    MouseLeave="AutoShowExplorerButton_MouseLeave"
                    ToolTip="탐색 표시">
                <TextBlock Text="탐색 표시"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextAlignment="Center">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="-90" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Button>
        </Popup>
    </Grid>
</Window>
